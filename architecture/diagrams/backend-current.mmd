flowchart TD
    classDef client fill:#1B4FD8,stroke:#1340B0,color:#fff
    classDef n8n fill:#0D9488,stroke:#0F766E,color:#fff
    classDef openai fill:#B45309,stroke:#92400E,color:#fff
    classDef gap fill:#C0392B,stroke:#922B21,color:#fff
    classDef storage fill:#5B4BD8,stroke:#3D2FB0,color:#fff
    classDef warn fill:#B45309,stroke:#92400E,color:#fff

    subgraph Browser["🌐 Browser (APP.html)"]
        UPLOAD["User uploads file\n(PDF / DOCX / TXT)"]:::client
        POST["POST Content-Type: text/plain\n\n{\n  file_name,\n  file_type,\n  file_content (base64),\n  standard: IFRS16,\n  analyzed_at\n}\n\n⚠️ No intent field\n⚠️ Not a binary attachment\n⚠️ No session_id / account_id"]:::warn
        FALLBACK["MOCK_ANALYSIS fallback\nHardcoded in APP.html\nused when response is\nnon-JSON or empty"]:::gap
    end

    subgraph N8N["⚙️ n8n Cloud — Real Multi-Agent Pipeline"]
        HOOK["Webhook trigger\nReceives POST body"]:::n8n

        EXTRACT["Extract from File\n(expects binary attachment\nin 'file' property)\n\n⚠️ MISMATCH: receives base64 JSON\nnot a binary file — node likely fails\n$json.text = undefined"]:::gap

        ORCH["Orchestrator Agent\ngpt-5-mini via OpenAI\n\nReads:\n• intent from webhook body ← undefined ⚠️\n• file text from Extract node ← undefined ⚠️\n\nDetects: intent + contract type\nCalls sub-agents in sequence"]:::openai

        subgraph SubAgents["Sub-Agents (all use gpt-5-mini + Shared Memory)"]
            PLAYBOOK["contract_playbook_agent\nFetches IFRS 16 playbook rules\nfor detected contract type\nfrom Supabase ✅"]:::n8n
            EXTRACT_AGENT["key_term_extraction_agent\nExtracts key terms from contract\nusing playbook rules from memory\nReturns structured JSON"]:::n8n
            MEMORY["Simple Memory\nShared buffer between all agents\nContextWindowLength: 50"]:::n8n
        end

        RESPOND["Respond to Webhook\nReturns agent output"]:::n8n

        HOOK --> EXTRACT --> ORCH
        ORCH --> SubAgents
        PLAYBOOK --> EXTRACT_AGENT
        MEMORY -.->|"shared context"| ORCH
        MEMORY -.->|"shared context"| PLAYBOOK
        MEMORY -.->|"shared context"| EXTRACT_AGENT
        SubAgents --> RESPOND
    end

    subgraph Supabase["💾 Supabase"]
        DB_READ["contract_playbook table\nRead ✅ — playbook rules\nper contract type\n(NDA / MSA)"]:::storage
        DB_WRITE["extraction results\nNot written ❌\nNo result persistence"]:::gap
    end

    subgraph OpenAI["🤖 OpenAI API"]
        MODEL["gpt-5-mini\nUsed by all three agents:\nOrchestrator + Playbook + Extraction"]:::openai
    end

    subgraph Response["📦 Response"]
        RESP["{\n  contract_type,\n  parties: [],\n  effective_date,\n  key_terms: [\n    { label, value }\n  ]\n}\n\n⚠️ No confidence scores\n⚠️ No clause_ref\n⚠️ No risk_score / flags\n⚠️ No error envelope\n⚠️ No status field"]:::gap
    end

    UPLOAD --> POST --> HOOK
    POST -.->|"timeout / error"| FALLBACK
    ORCH <-->|"LLM calls"| MODEL
    PLAYBOOK <-->|"LLM calls"| MODEL
    EXTRACT_AGENT <-->|"LLM calls"| MODEL
    PLAYBOOK <-->|"fetch rules"| DB_READ
    RESPOND --> Response
    Response -->|"200 OK"| Browser
