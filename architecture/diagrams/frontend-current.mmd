flowchart TD
    classDef screen fill:#1B4FD8,stroke:#1340B0,color:#fff
    classDef action fill:#0D9488,stroke:#0F766E,color:#fff
    classDef gap fill:#C0392B,stroke:#922B21,color:#fff
    classDef build fill:#0F1923,stroke:#000,color:#fff
    classDef warn fill:#B45309,stroke:#92400E,color:#fff

    BUILD["🔧 build.sh\nInjects WEBHOOK_URL via sed\nOutputs dist/index.html"]:::build
    NETLIFY["☁️ Netlify CDN\nServes dist/index.html"]:::build
    BUILD --> NETLIFY --> S1

    S1["📊 Screen 1 — Dashboard\nStatic hardcoded lease table\n(no real data)"]:::screen
    S2["📄 Screen 2 — Lease Analysis\nUpload + Results"]:::screen
    S3["📋 Screen 3 — Playbooks\nIFRS 16 fields, read-only"]:::screen

    S1 -->|"Upload a lease"| UPLOAD
    UPLOAD["📁 File selected\nonFileSelected()"]:::action
    CONSENT["🔒 Consent modal\nshowConsentModal()"]:::action
    UPLOAD --> CONSENT --> ANALYZE

    ANALYZE["⚙️ runAnalysis()\nReads file as base64\n\nPOST Content-Type: text/plain\n{\n  file_name,\n  file_type,\n  file_content (base64),\n  standard: IFRS16,\n  analyzed_at\n}\n\n⚠️ No intent field sent\n⚠️ No binary attachment\n⚠️ No session_id / account_id"]:::warn

    ANALYZE -->|"30s timeout"| WEBHOOK
    WEBHOOK["🔗 n8n Webhook\ncfalcon.app.n8n.cloud"]:::action

    WEBHOOK -->|"200 OK"| PARSE
    WEBHOOK -->|"timeout / error"| DEMO

    PARSE["📦 Parse response\nJSON.parse(text)\nif Array → take [0]"]:::action
    PARSE -->|"valid JSON"| RESULTS
    PARSE -->|"non-JSON / empty"| DEMO

    DEMO["⚠️ MOCK_ANALYSIS fallback\nHardcoded in APP.html\nshown when webhook fails\nor returns non-JSON"]:::gap

    RESULTS["✅ renderResults(data)\nTerms grid + Risk flags\nClause citations"]:::action
    RESULTS --> GATE

    GATE["🚦 Report Gate\nBlocks if High flags unresolved\nor sign-off empty"]:::action
    GATE -->|"All clear"| EXPORT

    EXPORT["📤 Export PDF\nButton wired — PDF not generated ❌"]:::gap

    CITATIONS["🔗 Clause citations\nLinks render but open nothing\nBUG-006 ❌"]:::gap
    PERSIST["💾 Persistence\nNone — data lost on refresh\nBUG-009 ❌"]:::gap
    TRACKING["📊 Event tracking\nStubs only → console.debug\nNo real destination ❌"]:::gap

    RESULTS --> CITATIONS
    RESULTS --> PERSIST
    RESULTS -.-> TRACKING
