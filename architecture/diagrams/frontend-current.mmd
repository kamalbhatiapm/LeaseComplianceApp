flowchart TD
    classDef screen fill:#1B4FD8,stroke:#1340B0,color:#fff,rx:6
    classDef action fill:#0D9488,stroke:#0F766E,color:#fff
    classDef gap fill:#C0392B,stroke:#922B21,color:#fff
    classDef storage fill:#6B7E8D,stroke:#3D4F5C,color:#fff
    classDef build fill:#0F1923,stroke:#000,color:#fff

    BUILD["🔧 build.sh\nInjects WEBHOOK_URL via sed\nOutputs dist/index.html"]:::build
    NETLIFY["☁️ Netlify CDN\nServes dist/index.html"]:::build

    BUILD --> NETLIFY

    NETLIFY --> S1

    S1["📊 Screen 1 — Dashboard\nStatic hardcoded lease table"]:::screen
    S2["📄 Screen 2 — Lease Analysis\nUpload + Results"]:::screen
    S3["📋 Screen 3 — Playbooks\nIFRS 16 fields read-only"]:::screen

    S1 -->|"Upload a lease"| UPLOAD
    UPLOAD["📁 File selected\nonFileSelected()"]:::action
    CONSENT["🔒 Consent modal\nshowConsentModal()"]:::action
    UPLOAD --> CONSENT --> ANALYZE

    ANALYZE["⚙️ runAnalysis()\nPOST filename + filesize\n+ filetype + timestamp\nNO document text ⚠️"]:::action

    ANALYZE -->|"30s timeout"| WEBHOOK
    WEBHOOK["🔗 n8n Webhook\ncfalcon.app.n8n.cloud"]:::action

    WEBHOOK -->|"200 OK — mock data"| RESULTS
    WEBHOOK -->|"error / timeout"| DEMO

    DEMO["⚠️ Demo fallback\nHardcoded in HTML"]:::gap
    RESULTS["✅ renderResults()\nTerms grid + Risk flags\nClause citations"]:::action

    RESULTS --> GATE
    GATE["🚦 Report Gate\nBlocks if High flags unresolved\nor sign-off empty"]:::action

    GATE -->|"All clear"| EXPORT
    EXPORT["📤 Export PDF\n(button wired, PDF not generated)"]:::gap

    RESULTS --> CITATIONS
    CITATIONS["🔗 Clause citations\nLinks render but open nothing\nBUG-006 ❌"]:::gap

    RESULTS --> PERSIST
    PERSIST["💾 Persistence\nNONE — data lost on refresh\nBUG-009 ❌"]:::gap

    TRACKING["📊 Event tracking\nStubs only → console.debug\nNo real analytics ❌"]:::gap
    RESULTS -.-> TRACKING

    S2 --- RESULTS
