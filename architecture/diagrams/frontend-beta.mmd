flowchart TD
    classDef screen fill:#1B4FD8,stroke:#1340B0,color:#fff
    classDef action fill:#0D9488,stroke:#0F766E,color:#fff
    classDef new fill:#0E8A5F,stroke:#065A3E,color:#fff
    classDef storage fill:#5B4BD8,stroke:#3D2FB0,color:#fff
    classDef build fill:#0F1923,stroke:#000,color:#fff

    BUILD["🔧 build.sh\nInjects WEBHOOK_URL\nSUPABASE_URL\nSUPABASE_ANON_KEY"]:::build
    NETLIFY["☁️ Netlify CDN"]:::build
    BUILD --> NETLIFY

    AUTH["🔐 Supabase Auth ✨\nMagic link login\nReturns account_id + JWT"]:::new
    NETLIFY --> AUTH

    AUTH --> S1

    S1["📊 Screen 1 — Dashboard\nReal lease table from Supabase ✨"]:::screen
    S2["📄 Screen 2 — Lease Analysis"]:::screen
    S3["📋 Screen 3 — Playbooks"]:::screen

    S1 -->|"Upload a lease"| UPLOAD
    UPLOAD["📁 File selected\nonFileSelected()"]:::action

    EXTRACT["📝 Extract document text ✨\nPDF.js for PDFs\nmammoth.js for DOCX\nCapped at 100k chars"]:::new
    UPLOAD --> EXTRACT

    CONSENT["🔒 Consent modal"]:::action
    EXTRACT --> CONSENT --> ANALYZE

    ANALYZE["⚙️ runAnalysis()\nPOST session_id + account_id\n+ standard + filename\n+ document_text ✨"]:::action

    WEBHOOK["🔗 n8n Webhook\nReal Claude extraction ✨"]:::action
    ANALYZE -->|"30s timeout"| WEBHOOK

    WEBHOOK -->|"200 OK — real data"| RESULTS
    WEBHOOK -->|"error envelope"| TOAST
    TOAST["🔔 Toast with error reason\nfrom error envelope ✨"]:::new

    RESULTS["✅ renderResults()\nTerms + confidence scores ✨\nMissing fields section ✨\nClause citations"]:::action

    VIEWER["🔍 PDF Clause Viewer ✨\nModal opens on citation click\nHighlights source clause\nBUG-006 resolved ✅"]:::new
    RESULTS -->|"clause click"| VIEWER

    GATE["🚦 Report Gate\nHigh flags block export"]:::action
    RESULTS --> GATE

    EXPORT["📤 Export PDF ✨\nGenerated from real data"]:::new
    GATE -->|"All clear"| EXPORT

    PERSIST["💾 Supabase DB ✨\nSave extraction per session\nLoad on page refresh\nBUG-009 resolved ✅"]:::new
    RESULTS --> PERSIST
    PERSIST -.->|"restore on refresh"| RESULTS

    TRACK["📊 Analytics ✨\nupload_started\nanalysis_complete\nflag_resolved\nreport_exported"]:::new
    RESULTS -.-> TRACK
    GATE -.-> TRACK
