flowchart TD
    classDef user fill:#1B4FD8,stroke:#1340B0,color:#fff
    classDef frontend fill:#0D9488,stroke:#0F766E,color:#fff
    classDef backend fill:#0D9488,stroke:#0F766E,color:#fff
    classDef openai fill:#B45309,stroke:#92400E,color:#fff
    classDef storage fill:#5B4BD8,stroke:#3D2FB0,color:#fff
    classDef gap fill:#C0392B,stroke:#922B21,color:#fff
    classDef warn fill:#B45309,stroke:#92400E,color:#fff
    classDef infra fill:#3D4F5C,stroke:#0F1923,color:#fff

    RACHEL["👩‍💼 Rachel\nCompliance Lead\nUploads lease contract"]:::user

    subgraph FE["Frontend — Netlify (APP.html)"]
        direction TB
        NO_AUTH["🔐 No auth\nNo session identity\nNo account_id"]:::gap
        UPLOAD_FE["📁 File selected\nRead as base64"]:::frontend
        CONSENT_FE["🔒 Consent modal"]:::frontend
        B64["📝 fileToBase64()\nConverts binary to base64 string\nWrapped in JSON payload"]:::warn
        SEND["⚙️ POST Content-Type: text/plain\n{ file_name, file_type,\n  file_content (base64),\n  standard, analyzed_at }\n\n⚠️ No binary attachment\n⚠️ No intent field\n⚠️ No session_id"]:::warn
        PARSE_FE["📦 Parse response\nJSON.parse → renderResults()"]:::frontend
        FALLBACK_FE["⚠️ MOCK_ANALYSIS\nFallback when webhook\nfails or non-JSON"]:::gap
        GATE_FE["🚦 Report Gate\nHigh flags must be resolved"]:::frontend
        EXPORT_FE["📤 Export PDF\nButton wired\nPDF not generated ❌"]:::gap
        CLAUSE_FE["🔗 Clause citations\nRender but open nothing\nBUG-006 ❌"]:::gap
        NOPERSIST["💾 No persistence\nPage refresh = data lost\nBUG-009 ❌"]:::gap

        NO_AUTH --> UPLOAD_FE --> B64 --> CONSENT_FE --> SEND
        SEND -->|"200 OK"| PARSE_FE
        SEND -.->|"timeout / error"| FALLBACK_FE
        PARSE_FE --> GATE_FE --> EXPORT_FE
        PARSE_FE --> CLAUSE_FE
        PARSE_FE --> NOPERSIST
    end

    subgraph BE["Backend — n8n Cloud"]
        direction TB
        HOOK_BE["🔗 Webhook trigger"]:::backend
        EXTRACT_BE["Extract from File\n(expects binary in 'file' property)\n⚠️ Receives base64 JSON instead\n→ $json.text = undefined"]:::gap
        ORCH_BE["🤖 Orchestrator Agent\ngpt-5-mini\n\nIntent: reads body.intent ← undefined ⚠️\nFile text: reads $json.text ← undefined ⚠️"]:::openai
        PLAY_BE["contract_playbook_agent\nFetches rules from Supabase\nby detected contract_type ✅"]:::backend
        EXTR_BE["key_term_extraction_agent\nExtracts terms using\nplaybook rules from memory"]:::backend
        MEM_BE["Simple Memory\nShared between all agents"]:::backend
        RESP_BE["Respond to Webhook\n{ contract_type, parties,\n  effective_date, key_terms[] }\n\n⚠️ No risk_score / flags\n⚠️ No confidence scores\n⚠️ No clause_ref\n⚠️ No error envelope"]:::warn

        HOOK_BE --> EXTRACT_BE --> ORCH_BE
        ORCH_BE --> PLAY_BE --> EXTR_BE --> RESP_BE
        MEM_BE -.->|"shared context"| ORCH_BE
        MEM_BE -.->|"shared context"| PLAY_BE
        MEM_BE -.->|"shared context"| EXTR_BE
    end

    subgraph OPENAI["🤖 OpenAI API"]
        GPT["gpt-5-mini\nAll three agents share\nthis single LLM connection"]:::openai
    end

    subgraph SUPA["💾 Supabase"]
        PLAY_DB["contract_playbook table\n✅ Read — playbook rules\nby contract type"]:::storage
        RESULTS_DB["Extraction results\n❌ Not written\nNo persistence"]:::gap
    end

    AUDITOR["🏦 External Auditor\nReceives PDF export\n(manual process today)"]:::user

    RACHEL -->|"upload file"| FE
    SEND -->|"POST base64 JSON"| BE
    ORCH_BE <-->|"LLM calls"| GPT
    PLAY_BE <-->|"LLM calls"| GPT
    EXTR_BE <-->|"LLM calls"| GPT
    PLAY_BE <-->|"read playbook rules"| PLAY_DB
    RESP_BE -->|"JSON response"| FE
    EXPORT_FE -.->|"manual PDF handoff"| AUDITOR
